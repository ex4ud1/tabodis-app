# ==== Supabase ====
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only — never expose to browser
SUPABASE_SERVICE_ROLE_KEY=

# ==== Resend (email delivery) ====
# Get key at https://resend.com/api-keys (FREE tier 3000/mo)
RESEND_API_KEY=
# From-address (after domain verification, otherwise onboarding@resend.dev)
RESEND_FROM_EMAIL=onboarding@resend.dev
# Where lead notifications get sent
LEADS_NOTIFY_EMAIL=

# ==== Site config ====
NEXT_PUBLIC_SITE_URL=https://tabodis-app.vercel.app
NEXT_PUBLIC_WHATSAPP=+34624121047

# ==== Optional: Analytics & monitoring (free tiers) ====
NEXT_PUBLIC_CLARITY_ID=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# ==== Optional: Rate limiting (Upstash Redis FREE tier) ====
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
